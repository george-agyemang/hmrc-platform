// prisma/schema.prisma
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  passwordHash  String?   // Hashed with bcrypt — never store plaintext
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  businesses    Business[]
  hmrcTokens    HmrcToken[]
}

model Business {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])

  // HMRC identifiers
  vrn           String?   @unique  // VAT Registration Number
  utr           String?   @unique  // Unique Taxpayer Reference (ITSA)
  crn           String?   @unique  // Company Registration Number (Corp Tax)

  businessName  String
  businessType  BusinessType
  status        BusinessStatus @default(ACTIVE)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  submissions   Submission[]
}

model HmrcToken {
  id            String    @id @default(uuid())
  userId        String    @unique   // One token set per user
  user          User      @relation(fields: [userId], references: [id])

  accessToken   String    @db.Text
  refreshToken  String    @db.Text
  scope         String
  expiresAt     DateTime

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Submission {
  id            String    @id @default(uuid())
  businessId    String
  business      Business  @relation(fields: [businessId], references: [id])

  taxType       TaxType   // VAT, ITSA, CORP_TAX
  periodKey     String    // HMRC period identifier e.g. "23AA"
  periodStart   DateTime
  periodEnd     DateTime

  submissionType SubmissionType  // NIL or DORMANT
  hmrcReceiptId String?         // Confirmation ID returned by HMRC
  status        SubmissionStatus @default(PENDING)

  payload       Json      // The exact payload sent to HMRC
  hmrcResponse  Json?     // The full response from HMRC

  submittedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([businessId])
}

enum BusinessType {
  SOLE_TRADER
  LIMITED_COMPANY
  PARTNERSHIP
}

enum BusinessStatus {
  ACTIVE
  DORMANT
}

enum TaxType {
  VAT
  ITSA
  CORP_TAX
}

enum SubmissionType {
  NIL
  DORMANT
}

enum SubmissionStatus {
  PENDING
  SUBMITTED
  ACCEPTED
  REJECTED
  ERROR
}
